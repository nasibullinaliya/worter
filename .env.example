# Copy to .env and fill in real values
# Used by: docker-compose.yml (local dev) and docker-compose.prod.yml (self-hosted)

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-32-chars

# PostgreSQL (production / self-hosted only)
POSTGRES_DB=vocab
POSTGRES_USER=vocab
POSTGRES_PASSWORD=change-me-strong-password

# URLs (production / self-hosted only)
FRONTEND_URL=https://your-app.vercel.app
API_URL=https://your-api.onrender.com

# Self-hosted alternative:
# FRONTEND_URL=http://localhost
# API_URL=http://localhost:8080
